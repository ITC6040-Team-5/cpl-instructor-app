# NUPathway — Required Environment Variables
# Copy this file to .env for local development (never commit .env)
# For Azure: set these in App Service → Configuration → Application settings

# ── Azure SQL Database ─────────────────────────────────────────────
SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=your-server.database.windows.net;Database=your-db;Uid=your-user;Pwd=your-password;Encrypt=yes;TrustServerCertificate=no;

# ── Azure OpenAI ───────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure Blob Storage (for evidence files) ────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=evidence-uploads

# ── App Behavior ───────────────────────────────────────────────────
# Set to "true" to seed demo data on first run (set to "false" in production)
SEED_DEMO_DATA=true
